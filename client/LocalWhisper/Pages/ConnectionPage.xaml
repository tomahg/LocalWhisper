<Page
    x:Class="LocalWhisper.Pages.ConnectionPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <ScrollViewer>
        <StackPanel Spacing="4" Margin="0,0,0,24">
            <TextBlock Text="Tilkobling" Style="{StaticResource TitleTextBlockStyle}" Margin="0,0,0,12"/>

            <!-- Server connection card -->
            <Border Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                    BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                    BorderThickness="1" CornerRadius="8" Padding="16">
                <StackPanel Spacing="12">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <FontIcon Grid.Column="0" Glyph="&#xE774;" FontSize="16"
                                  VerticalAlignment="Center" Margin="0,0,14,0"
                                  Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                        <StackPanel Grid.Column="1" VerticalAlignment="Center">
                            <TextBlock Text="Server" Style="{StaticResource BodyStrongTextBlockStyle}"/>
                            <TextBlock Text="WebSocket-adresse til transkripsjonsserveren"
                                       Foreground="{ThemeResource TextFillColorSecondaryBrush}" FontSize="12"/>
                        </StackPanel>
                        <StackPanel Grid.Column="2" Orientation="Horizontal" Spacing="6" VerticalAlignment="Center">
                            <Ellipse x:Name="StatusDot" Width="8" Height="8" Fill="#888" Margin="18,0,0,0"/>
                            <TextBlock x:Name="StatusText" Text="Frakoblet" FontSize="12"
                                       Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                       VerticalAlignment="Center"/>
                        </StackPanel>
                    </Grid>
                    <TextBox x:Name="ServerUrlBox"
                             PlaceholderText="ws://localhost:8765/ws/transcribe"/>
                    <StackPanel Orientation="Horizontal" Spacing="8">
                        <Button x:Name="ConnectButton" Content="Koble til"
                                Style="{StaticResource AccentButtonStyle}"
                                Click="ConnectButton_Click"/>
                        <Button x:Name="DisconnectButton" Content="Koble fra"
                                Click="DisconnectButton_Click" IsEnabled="False"/>
                    </StackPanel>
                </StackPanel>
            </Border>

            <!-- Auto-connect card -->
            <Border Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                    BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                    BorderThickness="1" CornerRadius="8" Padding="16,12">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <FontIcon Grid.Column="0" Glyph="&#xE895;" FontSize="16"
                              VerticalAlignment="Center" Margin="0,0,14,0"
                              Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                    <StackPanel Grid.Column="1" VerticalAlignment="Center">
                        <TextBlock Text="Automatisk tilkobling"/>
                        <TextBlock Text="Koble til serveren ved oppstart"
                                   Foreground="{ThemeResource TextFillColorSecondaryBrush}" FontSize="12"/>
                    </StackPanel>
                    <ToggleSwitch x:Name="AutoConnectToggle" Grid.Column="2"
                                  OnContent="" OffContent="" MinWidth="0" Margin="16,0,0,0"
                                  Toggled="AutoConnect_Changed"
                                  VerticalAlignment="Center"/>
                </Grid>
            </Border>

            <InfoBar x:Name="ErrorBar" IsOpen="False" Severity="Error" IsClosable="True"
                     Margin="0,8,0,0"/>
        </StackPanel>
    </ScrollViewer>
</Page>
