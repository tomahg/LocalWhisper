<Page
    x:Class="LocalWhisper.Pages.AudioPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <ScrollViewer>
        <StackPanel Spacing="4" Margin="0,0,0,24">
            <TextBlock Text="Lyd" Style="{StaticResource TitleTextBlockStyle}" Margin="0,0,0,12"/>

            <!-- Grouped card: Microphone + Auto-copy -->
            <Border Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                    BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                    BorderThickness="1" CornerRadius="8">

                <StackPanel>
                    <!-- Audio source row -->
                    <StackPanel Padding="16" Spacing="12">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <FontIcon Grid.Column="0" Glyph="&#xE767;" FontSize="16"
                                      VerticalAlignment="Center" Margin="0,0,14,0"
                                      Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                            <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                <TextBlock Text="Lydkilde" Style="{StaticResource BodyStrongTextBlockStyle}"/>
                                <TextBlock Text="Hva skal transkriberes"
                                           Foreground="{ThemeResource TextFillColorSecondaryBrush}" FontSize="12"/>
                            </StackPanel>
                        </Grid>
                        <ComboBox x:Name="AudioSourceComboBox" HorizontalAlignment="Stretch"
                                  SelectionChanged="AudioSource_SelectionChanged">
                            <ComboBoxItem Content="Mikrofon"/>
                            <ComboBoxItem Content="Datalyd (loopback)"/>
                            <ComboBoxItem Content="Begge"/>
                        </ComboBox>
                    </StackPanel>

                    <!-- Divider -->
                    <Border Height="1" Background="{ThemeResource CardStrokeColorDefaultBrush}"/>

                    <!-- Microphone row (hidden when source is SystemAudio) -->
                    <StackPanel x:Name="MicSection" Padding="16" Spacing="12">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <FontIcon Grid.Column="0" Glyph="&#xE720;" FontSize="16"
                                      VerticalAlignment="Center" Margin="0,0,14,0"
                                      Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                            <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                <TextBlock Text="Mikrofon" Style="{StaticResource BodyStrongTextBlockStyle}"/>
                                <TextBlock Text="Enhet for lydopptak"
                                           Foreground="{ThemeResource TextFillColorSecondaryBrush}" FontSize="12"/>
                            </StackPanel>
                        </Grid>
                        <ComboBox x:Name="MicComboBox" HorizontalAlignment="Stretch"
                                  SelectionChanged="MicComboBox_SelectionChanged"/>
                    </StackPanel>

                    <!-- Divider (hidden together with mic section) -->
                    <Border x:Name="MicDivider" Height="1" Background="{ThemeResource CardStrokeColorDefaultBrush}"/>

                    <!-- Auto-send on silence row -->
                    <Grid Padding="16,14">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <FontIcon Grid.Column="0" Glyph="&#xE71E;" FontSize="16"
                                  VerticalAlignment="Center" Margin="0,0,14,0"
                                  Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                        <StackPanel Grid.Column="1" VerticalAlignment="Center">
                            <TextBlock Text="Auto-send ved stillhet"/>
                            <TextBlock Text="Send transkripsjon automatisk ved pause i tale"
                                       Foreground="{ThemeResource TextFillColorSecondaryBrush}" FontSize="12"/>
                        </StackPanel>
                        <ToggleSwitch x:Name="AutoSilenceToggle" Grid.Column="2"
                                      OnContent="" OffContent="" MinWidth="0" Margin="16,0,0,0"
                                      Toggled="AutoSilence_Changed"
                                      VerticalAlignment="Center"/>
                    </Grid>

                    <!-- Silence threshold row (visible when toggle is on) -->
                    <Grid x:Name="SilenceThresholdRow" Padding="16,0,16,14" Visibility="Collapsed">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="1" Text="Ventetid (sekunder)"
                                   VerticalAlignment="Center"
                                   Foreground="{ThemeResource TextFillColorSecondaryBrush}" FontSize="12"
                                   Margin="30,0,0,0"/>
                        <NumberBox x:Name="SilenceThresholdBox" Grid.Column="2"
                                   Minimum="0.1" Maximum="10" SmallChange="0.1" LargeChange="1"
                                   SpinButtonPlacementMode="Inline"
                                   ValueChanged="SilenceThreshold_Changed"
                                   MinWidth="120"/>
                    </Grid>

                    <!-- Silence level row (visible when toggle is on) -->
                    <StackPanel x:Name="SilenceLevelRow" Padding="16,0,16,14" Spacing="4" Visibility="Collapsed">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="Lydnivåterskel"
                                       VerticalAlignment="Center" FontSize="12"
                                       Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                       Margin="30,0,0,0"/>
                            <TextBlock x:Name="SilenceLevelLabel" Grid.Column="1"
                                       VerticalAlignment="Center" FontSize="12"
                                       Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                        </Grid>
                        <Slider x:Name="SilenceLevelSlider"
                                Minimum="0.000" Maximum="0.020" StepFrequency="0.001"
                                ValueChanged="SilenceLevel_Changed"/>

                        <!-- Calibrate row -->
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock x:Name="SilenceLevelStatusText" Grid.Column="0"
                                       VerticalAlignment="Center" FontSize="12"
                                       Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                       Visibility="Collapsed"/>
                            <Button x:Name="SilenceLevelCalibrateButton" Grid.Column="1"
                                    Content="Kalibrér stillhet"
                                    Click="SilenceLevelCalibrateButton_Click"/>
                        </Grid>
                    </StackPanel>


                </StackPanel>
            </Border>
        <!-- VAD card -->
            <Border Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                    BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                    BorderThickness="1" CornerRadius="8">
                <StackPanel>

                    <!-- VAD enabled toggle -->
                    <Grid Padding="16,14">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <FontIcon Grid.Column="0" Glyph="&#xE9F5;" FontSize="16"
                                  VerticalAlignment="Center" Margin="0,0,14,0"
                                  Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                        <StackPanel Grid.Column="1" VerticalAlignment="Center">
                            <TextBlock Text="Talegjenkjenning (VAD)"/>
                            <TextBlock Text="Filtrer vekk bakgrunnsstøy automatisk"
                                       Foreground="{ThemeResource TextFillColorSecondaryBrush}" FontSize="12"/>
                        </StackPanel>
                        <ToggleSwitch x:Name="VadEnabledToggle" Grid.Column="2"
                                      OnContent="" OffContent="" MinWidth="0" Margin="16,0,0,0"
                                      Toggled="VadEnabled_Changed"
                                      VerticalAlignment="Center"/>
                    </Grid>

                    <!-- Divider + threshold panel (collapsed when VAD off) -->
                    <Border x:Name="VadDivider" Height="1" Background="{ThemeResource CardStrokeColorDefaultBrush}"/>

                    <StackPanel x:Name="VadSettingsPanel" Padding="16,12,16,16" Spacing="8">

                        <!-- Threshold label row -->
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="Terskelverdi"
                                       VerticalAlignment="Center" FontSize="12"
                                       Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                            <TextBlock x:Name="VadThresholdLabel" Grid.Column="1"
                                       VerticalAlignment="Center" FontSize="12"
                                       Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                        </Grid>

                        <!-- Threshold slider -->
                        <Slider x:Name="VadThresholdSlider"
                                Minimum="0.10" Maximum="0.90" StepFrequency="0.05"
                                ValueChanged="VadThreshold_Changed"/>

                        <!-- Calibrate row -->
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock x:Name="CalibrateStatusText" Grid.Column="0"
                                       VerticalAlignment="Center" FontSize="12"
                                       Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                       Visibility="Collapsed"/>
                            <Button x:Name="CalibrateButton" Grid.Column="1"
                                    Content="Kalibrér støy"
                                    Click="CalibrateButton_Click"/>
                        </Grid>

                    </StackPanel>
                </StackPanel>
            </Border>

        </StackPanel>
    </ScrollViewer>
</Page>
