# Ordfeil-korreksjoner — kopier til corrections.yaml og tilpass
#
# wrong:         det transkriberte ordet (søk er ikke case-sensitiv)
# correct:       det riktige ordet (skrives alltid slik du oppgir det her)
# full_sentence: matcher bare et helt segment, eller hele setninger
#
# Eksempler:
corrections:
  - wrong: "Thomas"
    correct: "Tomas"
  - wrong: "Nova Care"
    correct: "Novacare"
  - wrong: "Enter"
    correct: "\n"
    full_sentence: true
  - wrong: "Enter, enter"
    correct: "\n\n"
    full_sentence: true
