# Ordfeil-korreksjoner — kopier til corrections.yaml og tilpass
#
# wrong:        det transkriberte ordet (søk er ikke case-sensitiv)
# correct:      det riktige ordet (skrives alltid slik du oppgir det her)
# full_segment: matcher bare et helt segment, ikke deler av et segment
#
# Eksempler:
corrections:
  - wrong: "Thomas"
    correct: "Tomas"
  - wrong: "Nova Care"
    correct: "Novacare"
  - wrong: "Enter"
    correct: "\n"
    full_segment: true
  - wrong: "Enter, enter"
    correct: "\n\n"
    full_segment: true
