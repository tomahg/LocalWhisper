<Page
    x:Class="LocalWhisper.Pages.DisplayPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <ScrollViewer>
        <StackPanel Spacing="4" Margin="0,0,0,24">
            <TextBlock Text="Visning" Style="{StaticResource TitleTextBlockStyle}" Margin="0,0,0,12"/>

            <Border Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                    BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                    BorderThickness="1" CornerRadius="8">

                <StackPanel>
                    <!-- Header row -->
                    <Grid Padding="16,14">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <FontIcon Grid.Column="0" Glyph="&#xE7F4;" FontSize="16"
                                  VerticalAlignment="Center" Margin="0,0,14,0"
                                  Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                        <StackPanel Grid.Column="1" VerticalAlignment="Center">
                            <TextBlock Text="Plassering av overlay" Style="{StaticResource BodyStrongTextBlockStyle}"/>
                            <TextBlock Text="Der transkripsjonsvindtet vises"
                                       Foreground="{ThemeResource TextFillColorSecondaryBrush}" FontSize="12"/>
                        </StackPanel>
                    </Grid>

                    <!-- Divider -->
                    <Border Height="1" Background="{ThemeResource CardStrokeColorDefaultBrush}"/>

                    <!-- Vertical position -->
                    <StackPanel Padding="16,12,16,12">
                        <TextBlock Text="Loddrett" FontSize="12" Margin="0,0,0,8"
                                   Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                        <StackPanel Orientation="Horizontal" Spacing="16">
                            <RadioButton x:Name="VPosTop"    Content="Øverst"  GroupName="OverlayVPos" Checked="Position_Checked"/>
                            <RadioButton x:Name="VPosBottom" Content="Nederst" GroupName="OverlayVPos" Checked="Position_Checked"/>
                        </StackPanel>
                    </StackPanel>

                    <!-- Divider -->
                    <Border Height="1" Background="{ThemeResource CardStrokeColorDefaultBrush}"/>

                    <!-- Horizontal position -->
                    <StackPanel Padding="16,12,16,16">
                        <TextBlock Text="Vannrett" FontSize="12" Margin="0,0,0,8"
                                   Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                        <StackPanel Orientation="Horizontal" Spacing="16">
                            <RadioButton x:Name="HPosLeft"   Content="Venstre" GroupName="OverlayHPos" Checked="Position_Checked"/>
                            <RadioButton x:Name="HPosCenter" Content="Midten"  GroupName="OverlayHPos" Checked="Position_Checked"/>
                            <RadioButton x:Name="HPosRight"  Content="Høyre"   GroupName="OverlayHPos" Checked="Position_Checked"/>
                        </StackPanel>
                    </StackPanel>
                </StackPanel>
            </Border>
        </StackPanel>
    </ScrollViewer>
</Page>
