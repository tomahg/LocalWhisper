<Window
    x:Class="LocalWhisperer.MainWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    Title="LocalWhisperer">

    <StackPanel Padding="24" Spacing="16">
        <TextBlock Text="LocalWhisperer" Style="{StaticResource TitleTextBlockStyle}"/>

        <StackPanel Orientation="Horizontal" Spacing="8">
            <TextBlock Text="Server:" VerticalAlignment="Center" Width="80"/>
            <TextBox x:Name="ServerUrlBox" Width="280" PlaceholderText="ws://localhost:8765"/>
            <Button Content="Koble til" Click="ConnectButton_Click"/>
        </StackPanel>

        <StackPanel Orientation="Horizontal" Spacing="8">
            <TextBlock Text="Status:" VerticalAlignment="Center" Width="80"/>
            <TextBlock x:Name="StatusText" Text="Frakoblet" VerticalAlignment="Center"/>
        </StackPanel>

        <TextBlock Text="Siste transkripsjon:" Margin="0,8,0,0"/>
        <TextBox x:Name="TranscriptionLog"
                 IsReadOnly="True"
                 AcceptsReturn="True"
                 Height="160"
                 FontFamily="Consolas"
                 FontSize="13"/>

        <StackPanel Orientation="Horizontal" Spacing="8">
            <Button x:Name="RecordButton" Content="Ta opp (test)" Click="RecordButton_Click" IsEnabled="False"/>
            <Button Content="Stopp" Click="StopButton_Click" IsEnabled="False" x:Name="StopButton"/>
        </StackPanel>

        <InfoBar x:Name="ErrorBar" IsOpen="False" Severity="Error"/>
    </StackPanel>
</Window>
