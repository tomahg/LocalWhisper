<Page
    x:Class="LocalWhisperer.Pages.ConnectionPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <StackPanel Spacing="16" MaxWidth="460" HorizontalAlignment="Left">
        <TextBlock Text="Tilkobling" Style="{StaticResource TitleTextBlockStyle}"/>

        <StackPanel Spacing="8">
            <TextBlock Text="Server-URL"/>
            <TextBox x:Name="ServerUrlBox"
                     PlaceholderText="ws://localhost:8765/ws/transcribe"
                     Width="400" HorizontalAlignment="Left"/>
        </StackPanel>

        <StackPanel Orientation="Horizontal" Spacing="8">
            <Button x:Name="ConnectButton"    Content="Koble til"   Click="ConnectButton_Click"/>
            <Button x:Name="DisconnectButton" Content="Koble fra"   Click="DisconnectButton_Click" IsEnabled="False"/>
        </StackPanel>

        <CheckBox x:Name="AutoConnectCheckBox"
                  Content="Koble til automatisk ved oppstart"
                  Checked="AutoConnect_Changed"
                  Unchecked="AutoConnect_Changed"/>

        <StackPanel Orientation="Horizontal" Spacing="8">
            <TextBlock Text="Status:" VerticalAlignment="Center"/>
            <TextBlock x:Name="StatusText" Text="Frakoblet" VerticalAlignment="Center"
                       Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
        </StackPanel>

        <InfoBar x:Name="ErrorBar" IsOpen="False" Severity="Error" IsClosable="True"/>
    </StackPanel>
</Page>
