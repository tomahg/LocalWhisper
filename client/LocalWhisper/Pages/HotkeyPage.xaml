<Page
    x:Class="LocalWhisper.Pages.HotkeyPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    KeyDown="Page_KeyDown"
    KeyUp="Page_KeyUp">

    <ScrollViewer>
        <StackPanel Spacing="4" Margin="0,0,0,24">
            <TextBlock Text="Hurtigtast" Style="{StaticResource TitleTextBlockStyle}" Margin="0,0,0,12"/>

            <!-- Grouped card: Hotkey + Hold-to-talk -->
            <Border Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                    BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                    BorderThickness="1" CornerRadius="8">

                <StackPanel>
                    <!-- Hotkey row -->
                    <Grid Padding="16,14">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <FontIcon Grid.Column="0" Glyph="&#xE765;" FontSize="16"
                                  VerticalAlignment="Center" Margin="0,0,14,0"
                                  Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                        <StackPanel Grid.Column="1" VerticalAlignment="Center">
                            <TextBlock Text="Aktiv hurtigtast" Style="{StaticResource BodyStrongTextBlockStyle}"/>
                            <TextBlock Text="Tast for å starte/stoppe opptak"
                                       Foreground="{ThemeResource TextFillColorSecondaryBrush}" FontSize="12"/>
                        </StackPanel>
                        <StackPanel Grid.Column="2" Orientation="Horizontal" Spacing="8" VerticalAlignment="Center" Margin="12,0,0,0">
                            <StackPanel x:Name="HotkeyBadges" Orientation="Horizontal" Spacing="6" VerticalAlignment="Center"/>
                            <Button x:Name="ChangeButton" Content="Endre..." Click="ChangeButton_Click"/>
                        </StackPanel>
                    </Grid>

                </StackPanel>
            </Border>

            <InfoBar x:Name="CapturingBar"
                     IsOpen="False" Severity="Informational" IsClosable="False"
                     Title="Venter på tast(er)..."
                     Message="Hold eventuelle modifikatorer (Ctrl, Shift, Alt) og trykk ønsket tast. ESC avbryter."
                     Margin="0,8,0,0"/>
        </StackPanel>
    </ScrollViewer>
</Page>
