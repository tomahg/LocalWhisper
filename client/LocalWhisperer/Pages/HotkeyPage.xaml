<Page
    x:Class="LocalWhisperer.Pages.HotkeyPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <StackPanel Spacing="16" MaxWidth="460" HorizontalAlignment="Left">
        <TextBlock Text="Hurtigtast" Style="{StaticResource TitleTextBlockStyle}"/>

        <StackPanel Spacing="4">
            <TextBlock Text="Aktiv hurtigtast"/>
            <TextBlock x:Name="HotkeyLabel"
                       Style="{StaticResource SubtitleTextBlockStyle}"
                       Foreground="{ThemeResource AccentTextFillColorPrimaryBrush}"/>
        </StackPanel>

        <ToggleSwitch x:Name="HoldToTalkToggle"
                      Header="Hold nede for å tale (slipp = stopp)"
                      Toggled="HoldToTalkToggle_Toggled"/>

        <InfoBar IsOpen="True" Severity="Informational" IsClosable="False"
                 Message="For å endre hurtigtast: rediger AppSettings og restart appen. Tastekonfigurasjon via UI kommer i en fremtidig versjon."/>
    </StackPanel>
</Page>
