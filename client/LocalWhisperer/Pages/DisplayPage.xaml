<Page
    x:Class="LocalWhisperer.Pages.DisplayPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <ScrollViewer>
        <StackPanel Spacing="4" Margin="0,0,0,24">
            <TextBlock Text="Visning" Style="{StaticResource TitleTextBlockStyle}" Margin="0,0,0,12"/>

            <Border Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                    BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                    BorderThickness="1" CornerRadius="8">

                <StackPanel>
                    <!-- Header row -->
                    <Grid Padding="16,14">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <FontIcon Grid.Column="0" Glyph="&#xE7F4;" FontSize="16"
                                  VerticalAlignment="Center" Margin="0,0,14,0"
                                  Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                        <StackPanel Grid.Column="1" VerticalAlignment="Center">
                            <TextBlock Text="Plassering av overlay" Style="{StaticResource BodyStrongTextBlockStyle}"/>
                            <TextBlock Text="Hjørne der transkripsjonsvindtet vises"
                                       Foreground="{ThemeResource TextFillColorSecondaryBrush}" FontSize="12"/>
                        </StackPanel>
                    </Grid>

                    <!-- Divider -->
                    <Border Height="1" Background="{ThemeResource CardStrokeColorDefaultBrush}"/>

                    <!-- Radio buttons -->
                    <StackPanel Padding="16,12,16,16" Spacing="8">
                        <RadioButton x:Name="PositionRight"  Content="Høyre" GroupName="OverlayPosition" Checked="Position_Checked"/>
                        <RadioButton x:Name="PositionCenter" Content="Midten" GroupName="OverlayPosition" Checked="Position_Checked"/>
                        <RadioButton x:Name="PositionLeft"   Content="Venstre" GroupName="OverlayPosition" Checked="Position_Checked"/>
                    </StackPanel>
                </StackPanel>
            </Border>
        </StackPanel>
    </ScrollViewer>
</Page>
