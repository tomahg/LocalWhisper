<Page
    x:Class="LocalWhisperer.Pages.AudioPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <StackPanel Spacing="16" MaxWidth="460" HorizontalAlignment="Left">
        <TextBlock Text="Lyd" Style="{StaticResource TitleTextBlockStyle}"/>

        <StackPanel Spacing="4">
            <TextBlock Text="Mikrofon"/>
            <ComboBox x:Name="MicComboBox" Width="360" HorizontalAlignment="Left"
                      SelectionChanged="MicComboBox_SelectionChanged"/>
        </StackPanel>
    </StackPanel>
</Page>
