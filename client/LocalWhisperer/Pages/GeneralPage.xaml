<Page
    x:Class="LocalWhisperer.Pages.GeneralPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <ScrollViewer>
        <StackPanel Spacing="4" MaxWidth="460" HorizontalAlignment="Left" Margin="0,0,0,24">
            <TextBlock Text="Generelt" Style="{StaticResource TitleTextBlockStyle}" Margin="0,0,0,12"/>

            <Border Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                    BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                    BorderThickness="1" CornerRadius="8">

                <StackPanel>
                    <!-- Header row -->
                    <Grid Padding="16,14">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <FontIcon Grid.Column="0" Glyph="&#xE97A;" FontSize="16"
                                  VerticalAlignment="Center" Margin="0,0,14,0"
                                  Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                        <StackPanel Grid.Column="1" VerticalAlignment="Center">
                            <TextBlock Text="Avslutning per segment" Style="{StaticResource BodyStrongTextBlockStyle}"/>
                            <TextBlock Text="Hva som legges til"
                                       Foreground="{ThemeResource TextFillColorSecondaryBrush}" FontSize="12"/>
                        </StackPanel>
                        <ComboBox x:Name="SilenceSuffixComboBox" Grid.Column="2"
                                  SelectionChanged="SilenceSuffix_Changed"
                                  MinWidth="160">
                            <ComboBoxItem Content="Mellomrom"/>
                            <ComboBoxItem Content="Linjeskift"/>
                            <ComboBoxItem Content="Dobbelt linjeskift"/>
                        </ComboBox>
                    </Grid>
                </StackPanel>
            </Border>
        </StackPanel>
    </ScrollViewer>
</Page>
