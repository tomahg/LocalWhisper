<Page
    x:Class="LocalWhisperer.Pages.GeneralPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <ScrollViewer>
        <StackPanel Spacing="4" Margin="0,0,0,24">
            <TextBlock Text="Generelt" Style="{StaticResource TitleTextBlockStyle}" Margin="0,0,0,12"/>

            <Border Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                    BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                    BorderThickness="1" CornerRadius="8">

                <StackPanel>
                    <!-- Start per segment row -->
                    <Grid Padding="16,14">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <FontIcon Grid.Column="0" Glyph="&#xE9D2;" FontSize="16"
                                  VerticalAlignment="Center" Margin="0,0,14,0"
                                  Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                        <StackPanel Grid.Column="1" VerticalAlignment="Center">
                            <TextBlock Text="Start per segment" Style="{StaticResource BodyStrongTextBlockStyle}"/>
                            <TextBlock Text="Hva som legges foran"
                                       Foreground="{ThemeResource TextFillColorSecondaryBrush}" FontSize="12"/>
                        </StackPanel>
                        <ComboBox x:Name="SegmentPrefixComboBox" Grid.Column="2"
                                  SelectionChanged="SegmentPrefix_Changed"
                                  MinWidth="160">
                            <ComboBoxItem Content="(Ingen)"/>
                            <ComboBoxItem Content="Mellomrom"/>
                            <ComboBoxItem Content="Bindestrek"/>
                            <ComboBoxItem Content="Stjerne"/>
                        </ComboBox>
                    </Grid>

                    <!-- Divider -->
                    <Border Height="1" Background="{ThemeResource CardStrokeColorDefaultBrush}"/>

                    <!-- Avslutning per segment row -->
                    <Grid Padding="16,14">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <FontIcon Grid.Column="0" Glyph="&#xE97A;" FontSize="16"
                                  VerticalAlignment="Center" Margin="0,0,14,0"
                                  Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                        <StackPanel Grid.Column="1" VerticalAlignment="Center">
                            <TextBlock Text="Avslutning per segment" Style="{StaticResource BodyStrongTextBlockStyle}"/>
                            <TextBlock Text="Hva som legges til"
                                       Foreground="{ThemeResource TextFillColorSecondaryBrush}" FontSize="12"/>
                        </StackPanel>
                        <ComboBox x:Name="SilenceSuffixComboBox" Grid.Column="2"
                                  SelectionChanged="SilenceSuffix_Changed"
                                  MinWidth="160">
                            <ComboBoxItem Content="(Ingen)"/>
                            <ComboBoxItem Content="Mellomrom"/>
                            <ComboBoxItem Content="Linjeskift"/>
                            <ComboBoxItem Content="Dobbelt linjeskift"/>
                        </ComboBox>
                    </Grid>
                </StackPanel>
            </Border>

            <Border Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                    BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                    BorderThickness="1" CornerRadius="8">

                <StackPanel>
                    <!-- Inject text directly row -->
                    <Grid Padding="16,14">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <FontIcon Grid.Column="0" Glyph="&#xE8AD;" FontSize="16"
                                  VerticalAlignment="Center" Margin="0,0,14,0"
                                  Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                        <StackPanel Grid.Column="1" VerticalAlignment="Center">
                            <TextBlock Text="Skriv tekst direkte inn" Style="{StaticResource BodyStrongTextBlockStyle}"/>
                            <TextBlock Text="Sender tekst til aktivt tekstfelt"
                                       Foreground="{ThemeResource TextFillColorSecondaryBrush}" FontSize="12"/>
                        </StackPanel>
                        <ToggleSwitch x:Name="InjectToggle" Grid.Column="2"
                                      OnContent="" OffContent="" MinWidth="0" Margin="16,0,0,0"
                                      Toggled="Inject_Changed"
                                      VerticalAlignment="Center"/>
                    </Grid>

                    <!-- Divider -->
                    <Border Height="1" Background="{ThemeResource CardStrokeColorDefaultBrush}"/>

                    <!-- Auto-copy row (hidden when inject is on) -->
                    <Grid x:Name="AutoCopyRow" Padding="16,14">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <FontIcon Grid.Column="0" Glyph="&#xE8C8;" FontSize="16"
                                  VerticalAlignment="Center" Margin="0,0,14,0"
                                  Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                        <StackPanel Grid.Column="1" VerticalAlignment="Center">
                            <TextBlock Text="Kopier automatisk"/>
                            <TextBlock Text="Kopier transkripsjon til utklippstavle"
                                       Foreground="{ThemeResource TextFillColorSecondaryBrush}" FontSize="12"/>
                        </StackPanel>
                        <ToggleSwitch x:Name="AutoCopyToggle" Grid.Column="2"
                                      OnContent="" OffContent="" MinWidth="0" Margin="16,0,0,0"
                                      Toggled="AutoCopy_Changed"
                                      VerticalAlignment="Center"/>
                    </Grid>
                </StackPanel>
            </Border>

            <Border Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                    BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                    BorderThickness="1" CornerRadius="8">

                <StackPanel>
                    <!-- Header row -->
                    <Grid Padding="16,14">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <FontIcon Grid.Column="0" Glyph="&#xE8AD;" FontSize="16"
                                  VerticalAlignment="Center" Margin="0,0,14,0"
                                  Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                        <StackPanel Grid.Column="1" VerticalAlignment="Center">
                            <TextBlock Text="Tekstinnliming" Style="{StaticResource BodyStrongTextBlockStyle}"/>
                            <TextBlock Text="Hvordan tekst skrives inn i aktivt felt"
                                       Foreground="{ThemeResource TextFillColorSecondaryBrush}" FontSize="12"/>
                        </StackPanel>
                    </Grid>

                    <!-- Divider -->
                    <Border Height="1" Background="{ThemeResource CardStrokeColorDefaultBrush}"/>

                    <!-- Radio buttons -->
                    <StackPanel Padding="16,12,16,16" Spacing="8">
                        <RadioButton x:Name="MethodType"  GroupName="InjectionMethod" Checked="Method_Checked">
                            <StackPanel>
                                <TextBlock Text="Skriv direkte"/>
                                <TextBlock Text="Tegn for tegn via SendInput"
                                           Foreground="{ThemeResource TextFillColorSecondaryBrush}" FontSize="12"/>
                            </StackPanel>
                        </RadioButton>
                        <RadioButton x:Name="MethodPaste" GroupName="InjectionMethod" Checked="Method_Checked">
                            <StackPanel>
                                <TextBlock Text="Lim inn via utklippstavle"/>
                                <TextBlock Text="Raskere, men bruker utklippstavlen"
                                           Foreground="{ThemeResource TextFillColorSecondaryBrush}" FontSize="12"/>
                            </StackPanel>
                        </RadioButton>
                    </StackPanel>
                </StackPanel>
            </Border>
        </StackPanel>
    </ScrollViewer>
</Page>
