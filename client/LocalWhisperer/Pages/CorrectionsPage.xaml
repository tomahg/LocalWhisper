<Page
    x:Class="LocalWhisperer.Pages.CorrectionsPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <ScrollViewer>
        <StackPanel Spacing="4" Margin="0,0,0,24">
            <TextBlock Text="Korreksjoner" Style="{StaticResource TitleTextBlockStyle}" Margin="0,0,0,12"/>

            <Border Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                    BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                    BorderThickness="1" CornerRadius="8">

                <StackPanel>
                    <!-- Header row -->
                    <Grid Padding="16,14">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <FontIcon Grid.Column="0" Glyph="&#xE8D3;" FontSize="16"
                                  VerticalAlignment="Center" Margin="0,0,14,0"
                                  Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                        <StackPanel Grid.Column="1" VerticalAlignment="Center">
                            <TextBlock Text="Orderstattninger" Style="{StaticResource BodyStrongTextBlockStyle}"/>
                            <TextBlock Text="Ord og fraser som erstattes automatisk i transkripsjonen"
                                       Foreground="{ThemeResource TextFillColorSecondaryBrush}" FontSize="12"/>
                        </StackPanel>
                    </Grid>

                    <!-- Divider -->
                    <Border Height="1" Background="{ThemeResource CardStrokeColorDefaultBrush}"/>

                    <!-- Add new correction row -->
                    <Grid Padding="16,12" ColumnSpacing="8">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <TextBox Grid.Column="0" x:Name="WrongBox"
                                 PlaceholderText="Erstatt..."
                                 KeyDown="InputBox_KeyDown"/>
                        <TextBlock Grid.Column="1" Text="→"
                                   VerticalAlignment="Center"
                                   Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                   Margin="4,0"/>
                        <TextBox Grid.Column="2" x:Name="CorrectBox"
                                 PlaceholderText="Med..."
                                 KeyDown="InputBox_KeyDown"/>
                        <Button Grid.Column="3" Content="Legg til"
                                Click="AddCorrection_Click"/>
                    </Grid>

                    <!-- Divider (only shown when list is non-empty) -->
                    <Border x:Name="ListDivider" Height="1"
                            Background="{ThemeResource CardStrokeColorDefaultBrush}"
                            Visibility="Collapsed"/>

                    <!-- Dynamically built list of corrections -->
                    <StackPanel x:Name="CorrectionsList"/>

                </StackPanel>
            </Border>
        </StackPanel>
    </ScrollViewer>
</Page>
